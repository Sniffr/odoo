<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Terms and Conditions Page - Revive Aesthetics -->
    <template id="terms_page" name="Terms and Conditions">
        <t t-call="website.layout">
            <t t-set="title">Terms and Conditions - Revive Aesthetics</t>
            <div id="wrap_terms">

                <!-- Hero Section -->
                <div class="terms-hero">
                    <div class="container">
                        <h1>Revive Aesthetics</h1>
                        <p class="subtitle">TERMS &amp; CONDITIONS</p>
                    </div>
                </div>

                <div class="container py-5">
                    <!-- Introduction -->
                    <div class="terms-intro">
                        <p class="mb-0" style="font-size: 1.1rem; color: rgba(255,255,255,0.7);">
                            <strong>By booking or receiving any service with Revive Aesthetics, you agree to the following Terms &amp; Conditions.</strong>
                        </p>
                    </div>

                    <!-- Section 1: Bookings and Payments -->
                    <div class="terms-section">
                        <h2><i class="fa fa-credit-card"></i> BOOKINGS &amp; PAYMENTS</h2>
                        <ul>
                            <li>A fixed booking fee of <span class="fee-badge">KES 500</span> is required to secure all appointments.</li>
                            <li>The booking fee will be deducted from the total service cost.</li>
                            <li>The booking fee is refundable only if cancellation is made within <strong>6-12 hours</strong> before the appointment.</li>
                            <li>Same-day bookings and walk-ins are accepted, subject to availability.</li>
                            <li>Late walk-ins may be accommodated at management's discretion.</li>
                        </ul>
                    </div>

                    <!-- Section 2: Cancellations -->
                    <div class="terms-section">
                        <h2><i class="fa fa-calendar-times-o"></i> CANCELLATIONS, RESCHEDULING &amp; NO-SHOWS</h2>
                        <ul>
                            <li>Clients may reschedule <strong>once</strong>, provided communication is made within <strong>12 hours</strong> of booking.</li>
                            <li>Cancellations due to illness or emergencies must be communicated early to allow rescheduling.</li>
                            <li>
                                <strong>No-Show Policy:</strong>
                                <ul>
                                    <li>Failure to show up within 1 hour without communication will be considered a no-show.</li>
                                    <li>No-shows automatically forfeit their booking fee.</li>
                                </ul>
                            </li>
                        </ul>
                    </div>

                    <!-- Section 3: Arrival -->
                    <div class="terms-section">
                        <h2><i class="fa fa-clock-o"></i> ARRIVAL &amp; TIME POLICY</h2>
                        <ul>
                            <li>Clients are encouraged to arrive at least <strong>10 minutes early</strong>.</li>
                            <li>
                                If a client arrives late but can still be served, the appointment may be:
                                <ul>
                                    <li>Shortened, or</li>
                                    <li>Adjusted to fit remaining availability.</li>
                                </ul>
                            </li>
                            <li>Evening appointments (6:30 PM onwards) attract an additional <span class="fee-badge">KES 500</span> convenience fee.</li>
                            <li>Appointments may be cancelled if delays disrupt the studio schedule.</li>
                        </ul>
                    </div>

                    <!-- Section 4: Lash Services -->
                    <div class="terms-section">
                        <h2><i class="fa fa-eye"></i> LASH SERVICES &amp; CLIENT RESPONSIBILITY</h2>
                        <p style="color: rgba(255,255,255,0.6); margin-bottom: 15px;">To ensure best results, clients agree to the following:</p>
                        <ul>
                            <li>Avoid caffeine before appointments.</li>
                            <li>Remove contact lenses before service.</li>
                            <li>
                                <div class="highlight-box">
                                    <strong>No makeup policy:</strong> Ensure that you come with no makeup or mascara on your lashes. Should you come with makeup, we shall charge <span class="fee-badge">KES 500</span> for extra cleaning.
                                </div>
                            </li>
                            <li>
                                Results may vary based on:
                                <ul>
                                    <li>The condition of natural lashes, especially if lashes are damaged.</li>
                                    <li>Client aftercare compliance.</li>
                                </ul>
                            </li>
                            <li>
                                Revive Aesthetics is <strong>not responsible</strong> for poor retention caused by:
                                <ul>
                                    <li>Failure to follow aftercare instructions.</li>
                                    <li>Lifestyle factors or external products.</li>
                                </ul>
                            </li>
                        </ul>
                    </div>

                    <!-- Section 5: Corrections -->
                    <div class="terms-section">
                        <h2><i class="fa fa-refresh"></i> CORRECTIONS, REFUNDS &amp; REDOS</h2>
                        <ul>
                            <li><strong>No refunds</strong> are issued under any circumstances.</li>
                            <li>Corrections are allowed within <strong>3 days</strong> of service.</li>
                            <li>Corrections are <strong>free of charge</strong> if reported within the stated timeframe.</li>
                            <li>Issues reported after 3 days will be treated as a new booking.</li>
                        </ul>
                    </div>

                    <!-- Section 6: House Calls -->
                    <div class="terms-section">
                        <h2><i class="fa fa-car"></i> HOUSE CALLS / MOBILE SERVICES</h2>
                        <ul>
                            <li>House calls require a <span class="fee-badge">KES 500</span> booking fee.</li>
                            <li>A <span class="fee-badge">KES 1,000</span> convenience fee plus transport to and from location applies.</li>
                            <li>Clients must communicate any location changes in advance.</li>
                            <li>Failure to communicate location changes may result in automatic cancellation.</li>
                        </ul>
                    </div>

                    <!-- Section 7: Health -->
                    <div class="terms-section">
                        <h2><i class="fa fa-heartbeat"></i> HEALTH, SAFETY &amp; CLIENT DISCLOSURE</h2>
                        <ul>
                            <li>
                                Clients must disclose:
                                <ul>
                                    <li>Allergies</li>
                                    <li>Eye conditions</li>
                                    <li>Pregnancy</li>
                                </ul>
                            </li>
                            <li>Clients are required to complete a <strong>consultation &amp; disclosure form</strong> before service.</li>
                            <li>Revive Aesthetics reserves the right to decline service if health concerns pose a risk.</li>
                        </ul>
                    </div>

                    <!-- Section 8: Conduct -->
                    <div class="terms-section">
                        <h2><i class="fa fa-users"></i> CONDUCT &amp; STUDIO ETIQUETTE</h2>
                        <ul>
                            <li>Extra guests and children are allowed but must wait in the reception area.</li>
                            <li>
                                Disruptive behavior, harassment, or disrespect toward staff will result in:
                                <ul>
                                    <li>Immediate termination of service</li>
                                    <li>Loss of booking fee</li>
                                </ul>
                            </li>
                            <li>Revive Aesthetics reserves the right to refuse service at any time.</li>
                        </ul>
                    </div>

                    <!-- Acceptance Box -->
                    <div class="acceptance-box">
                        <h3><i class="fa fa-check-circle mr-2"></i> ACCEPTANCE OF TERMS</h3>
                        <p style="font-size: 1.1rem;">
                            Booking an appointment confirms that you have read, understood, and agreed to these Terms &amp; Conditions.
                        </p>
                    </div>

                    <!-- Action Buttons -->
                    <div class="text-center mt-5">
                        <a href="/appointments" class="btn btn-lg btn-pink mr-3">
                            <i class="fa fa-calendar-plus-o mr-2"></i> Book Appointment
                        </a>
                        <a href="/" class="btn btn-lg btn-outline-pink">
                            <i class="fa fa-home mr-2"></i> Back to Home
                        </a>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
